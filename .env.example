# ============================================================
# 闲鱼自动回复程序 - 环境变量模板
# 复制为 .env 并按需修改(.env 不会进入版本库)
# ============================================================

# ---- 应用 ----
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8089

# ---- 数据库 ----
# 留空则默认使用 backend/data/app.sqlite(SQLite + WAL)
DATABASE_URL=

# ---- LLM(OpenAI 兼容接口,阶段4启用) ----
# 默认指向 DeepSeek,可改为通义/Kimi/OpenAI 等
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# ---- 告警 webhook(阶段6启用) ----
DINGTALK_WEBHOOK=
WECOM_WEBHOOK=

# ---- 日志 ----
LOG_LEVEL=INFO
